module WhopSDK
  module Models
    type ad_campaign_status =
      :active | :paused | :payment_failed | :draft | :in_review | :flagged

    module AdCampaignStatus
      extend WhopSDK::Internal::Type::Enum

      ACTIVE: :active
      PAUSED: :paused
      PAYMENT_FAILED: :payment_failed
      DRAFT: :draft
      IN_REVIEW: :in_review
      FLAGGED: :flagged

      def self?.values: -> ::Array[WhopSDK::Models::ad_campaign_status]
    end
  end
end
