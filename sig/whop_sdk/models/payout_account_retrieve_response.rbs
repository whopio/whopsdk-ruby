      attr_accessor business_name: String?

      attr_accessor business_representative: WhopSDK::Models::PayoutAccountRetrieveResponse::BusinessRepresentative?

      attr_accessor email: String?

      attr_accessor latest_verification: WhopSDK::Models::PayoutAccountRetrieveResponse::LatestVerification?

      attr_accessor phone: String?

      attr_accessor status: WhopSDK::Models::payout_account_calculated_statuses?

