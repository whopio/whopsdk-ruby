      class BusinessRepresentative < WhopSDK::Internal::Type::BaseModel
        attr_accessor date_of_birth: String?

        attr_accessor first_name: String?

        attr_accessor last_name: String?

        attr_accessor middle_name: String?

        def initialize: (
